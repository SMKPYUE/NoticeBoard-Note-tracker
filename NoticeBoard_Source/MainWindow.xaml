<Window x:Class="StoryBoardAI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StoryBoardAI"
        mc:Ignorable="d"
        Title="NoticeBoard" Height="720" Width="1120"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI" PreviewKeyDown="Window_PreviewKeyDown">

    <!-- WindowChrome enables native resize on borderless window -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="10"/>
    </WindowChrome.WindowChrome>
    
    <Window.Resources>
        <!-- Theming Brushes (Configured dynamically in code) -->
        <SolidColorBrush x:Key="PrimaryAccentBrush" Color="#5c2dd5"/>
        <SolidColorBrush x:Key="SecondaryAccentBGBrush" Color="#16122c"/>
        <SolidColorBrush x:Key="SecondaryAccentBorderBrush" Color="#3a2a6b"/>
        <SolidColorBrush x:Key="SecondaryAccentTextBrush" Color="#b39ddb"/>

        <!-- Converter for custom border colors -->
        <local:BorderColorConverter x:Key="BorderColorConverter"/>
        
        <!-- Custom Background & Count converters -->
        <local:BackgroundImageConverter x:Key="BackgroundImageConverter"/>
        <local:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Circular Color Button Style -->
        <Style x:Key="CircularColorButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark Context Menu Style -->
        <Style x:Key="DarkContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="#1a1a24"/>
            <Setter Property="BorderBrush" Value="#3a3a4c"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="2">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="#ffffff"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Padding" Value="12,6"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="MenuItem">
                                <Border x:Name="Border" Background="{TemplateBinding Background}" BorderThickness="0" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter ContentSource="Header" RecognizesAccessKey="True" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#5c2dd5"/>
                                        <Setter Property="Foreground" Value="#ffffff"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
        </Style>

        <!-- Dark ComboBox Toggle Button Template -->
        <ControlTemplate x:Key="DarkComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="28"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" Background="#1e1e28" BorderBrush="#2d2d3d" BorderThickness="1" CornerRadius="4"/>
                <Border Grid.Column="0" Background="Transparent" Margin="1"/>
                <Path x:Name="Arrow" Grid.Column="1" Fill="#a0a0b5" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="BorderBrush" Value="#4a4a5a"/>
                    <Setter TargetName="Arrow" Property="Fill" Value="#ffffff"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Border" Property="BorderBrush" Value="#5a5a6a"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Dark ComboBox Style -->
        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="Background" Value="#1e1e28"/>
            <Setter Property="BorderBrush" Value="#2d2d3d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#1e1e28"/>
                        <Setter Property="Foreground" Value="#dcdce5"/>
                        <Setter Property="Padding" Value="10,6"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" BorderThickness="0">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2d2d3d"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2d2d3d"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Template="{StaticResource DarkComboBoxToggleButton}"
                                          Focusable="False" IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"/>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" 
                                              Content="{TemplateBinding SelectionBoxItem}" 
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="10,3,28,3" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <TextBox x:Name="PART_EditableTextBox" Style="{x:Null}" 
                                     HorizontalAlignment="Left" VerticalAlignment="Center" 
                                     Margin="10,3,28,3" Focusable="True" Background="Transparent" 
                                     Foreground="#ffffff" CaretBrush="#ffffff"
                                     Visibility="Hidden" IsReadOnly="{TemplateBinding IsReadOnly}"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" 
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True" 
                                      MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#1a1a24" BorderBrush="#3a3a4c" 
                                            BorderThickness="1" CornerRadius="4" Margin="0,2,0,0">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="2" Opacity="0.5"/>
                                        </Border.Effect>
                                    </Border>
                                    <ScrollViewer Margin="1,4,1,4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- Custom Title Bar Button Style -->
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#a0a0b5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#252535"/>
                    <Setter Property="Foreground" Value="#ffffff"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Custom Title Bar Close Button Style (Red Hover) -->
        <Style x:Key="TitleBarCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#a0a0b5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#c42b2b"/>
                    <Setter Property="Foreground" Value="#ffffff"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Primary Accent Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PrimaryAccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3a3a4a"/>
                    <Setter Property="Foreground" Value="#707080"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Toggle Button Style for Pin -->
        <Style x:Key="PinToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3a3a4c"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5c2dd5"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary/Accent Button Style -->
        <Style x:Key="AccentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SecondaryAccentBGBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryAccentTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SecondaryAccentBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource SecondaryAccentTextBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Delete Button Style (Red Border/Background) -->
        <Style x:Key="DeleteButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2b1418"/>
            <Setter Property="Foreground" Value="#ff5e7e"/>
            <Setter Property="BorderBrush" Value="#4d1f27"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#441a22"/>
                    <Setter Property="BorderBrush" Value="#ff5e7e"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1d0a0d"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Segmented RadioButton Style for view switching -->
        <Style x:Key="AccentRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#a0a0b5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2d2d3d"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1e1e28"/>
                                <Setter Property="Foreground" Value="#ffffff"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5c2dd5"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#5c2dd5"/>
                                <Setter Property="Foreground" Value="#ffffff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <local:TagsListConverter x:Key="TagsListConverter"/>
    </Window.Resources>

    <Border Background="#121218" BorderBrush="#3a3a4c" BorderThickness="1.5" CornerRadius="10" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <!-- Title Bar (36px) -->
                <RowDefinition Height="Auto"/>
                <!-- Main Workspace Grid -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ==================== CUSTOM TITLE BAR ==================== -->
            <Grid Grid.Row="0" Background="#0f0f14" Height="36" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App Icon / Title -->
                <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                    <TextBlock Text="📌" Margin="0,0,8,0" VerticalAlignment="Center" FontSize="13"/>
                    <TextBlock Text="NoticeBoard" Foreground="#ffffff" FontWeight="SemiBold" FontSize="12.5" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Control Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,2,0">
                    <Button Content="─" Click="MinimizeBtn_Click" Style="{StaticResource TitleBarButtonStyle}"/>
                    <Button x:Name="MaximizeBtn" Content="▢" Click="MaximizeBtn_Click" Style="{StaticResource TitleBarButtonStyle}"/>
                    <Button Content="✕" Click="CloseBtn_Click" Style="{StaticResource TitleBarCloseButtonStyle}"/>
                </StackPanel>
            </Grid>

            <!-- ==================== WORKSPACE CONTENT ==================== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <!-- Storyboard Workspace (fills remaining space) -->
                    <ColumnDefinition Width="*"/>
                    <!-- Divider & Toggle Column -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Gemini Chat Panel (Auto width to allow collapsing) -->
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- ==================== LEFT PANEL: STORYBOARD WORKSPACE ==================== -->
                <Grid Grid.Column="0" Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel Orientation="Vertical" Margin="0,0,20,0">
                                <TextBlock Text="Workspace" FontSize="24" FontWeight="Bold" Foreground="#ffffff"/>
                                <TextBlock Text="Add, edit and organize your story" FontSize="11" Foreground="#8e8e9f" Margin="0,2,0,0"/>
                            </StackPanel>
                                                <!-- Workspace selector and filters -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                                <TextBlock Text="Workspace:" Foreground="#a0a0b5" VerticalAlignment="Center" FontSize="12.5" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                <ComboBox x:Name="WorkspaceComboBox" Width="140" Height="32" VerticalContentAlignment="Center"
                                          Style="{StaticResource DarkComboBoxStyle}"
                                          ItemsSource="{Binding Workspaces}" DisplayMemberPath="Name"
                                          SelectedItem="{Binding ActiveWorkspace, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <Button Content="+ New" Click="AddWorkspace_Click" Style="{StaticResource AccentButtonStyle}" Height="32" Margin="6,0,0,0" Padding="8,4" ToolTip="Create new workspace"/>
                                <Button Content="Export" Click="ExportWorkspace_Click" Style="{StaticResource AccentButtonStyle}" Height="32" Margin="6,0,0,0" Padding="8,4" ToolTip="Export workspace package"/>
                                <Button Content="Import" Click="ImportWorkspace_Click" Style="{StaticResource AccentButtonStyle}" Height="32" Margin="6,0,0,0" Padding="8,4" ToolTip="Import workspace package"/>
                                <Button Content="Delete" Click="DeleteWorkspace_Click" Style="{StaticResource DeleteButtonStyle}" Height="32" Margin="6,0,0,0" Padding="8,4" ToolTip="Delete current workspace"/>

                                <TextBlock Text="Filter Tag:" Foreground="#a0a0b5" VerticalAlignment="Center" FontSize="12.5" FontWeight="SemiBold" Margin="16,0,8,0"/>
                                <ComboBox x:Name="FilterComboBox" Width="100" Height="32" VerticalContentAlignment="Center"
                                          Style="{StaticResource DarkComboBoxStyle}"
                                          SelectionChanged="FilterComboBox_SelectionChanged"/>

                                <TextBlock Text="Smart Group:" Foreground="#a0a0b5" VerticalAlignment="Center" FontSize="12.5" FontWeight="SemiBold" Margin="16,0,8,0"/>
                                <ComboBox x:Name="SmartGroupComboBox" Width="120" Height="32" VerticalContentAlignment="Center"
                                          Style="{StaticResource DarkComboBoxStyle}"
                                          SelectionChanged="SmartGroupComboBox_SelectionChanged"/>
                                <Button Content="+" Click="AddSmartGroup_Click" Style="{StaticResource AccentButtonStyle}" Height="32" Margin="6,0,0,0" Padding="8,4" ToolTip="Create new Smart Group filter"/>
                                <Button Content="✕" Click="DeleteSmartGroup_Click" Style="{StaticResource DeleteButtonStyle}" Height="32" Margin="6,0,0,0" Padding="8,4" ToolTip="Delete active Smart Group"/>

                                <TextBlock Text="View:" Foreground="#a0a0b5" VerticalAlignment="Center" FontSize="12.5" FontWeight="SemiBold" Margin="16,0,8,0"/>
                                <RadioButton x:Name="BoardViewRadio" Content="Board" IsChecked="True" Style="{StaticResource AccentRadioButtonStyle}" Checked="ViewModeRadio_Click" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <RadioButton x:Name="GraphViewRadio" Content="Graph" Style="{StaticResource AccentRadioButtonStyle}" Checked="ViewModeRadio_Click" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Live Search Text Box -->
                            <Grid Margin="0,0,10,0">
                                <TextBox x:Name="SearchBar" Width="150" Height="38" VerticalContentAlignment="Center" Background="#1e1e28" Foreground="#ffffff" BorderBrush="#2d2d3d" BorderThickness="1" Padding="8,6" CaretBrush="#ffffff" TextChanged="SearchBar_TextChanged"/>
                                <TextBlock x:Name="SearchPlaceholder" Text="🔍 Search notes..." Foreground="#5a5a6a" Margin="8,0,0,0" IsHitTestVisible="False" VerticalAlignment="Center" FontSize="11"/>
                            </Grid>
                            <Button Content="Import Card" Click="ImportCard_Click" Style="{StaticResource AccentButtonStyle}" Height="38" Margin="0,0,10,0" Padding="12,6"/>
                            <Button Content="🏷 Manage Tags" Click="Tags_Click" Style="{StaticResource AccentButtonStyle}" Height="38" Margin="0,0,10,0" Padding="12,6"/>
                            <Button Content="⚙ Settings" Click="Settings_Click" Style="{StaticResource AccentButtonStyle}" Height="38" Margin="0,0,10,0" Padding="12,6"/>
                            <Button Content="+ New Card" Click="AddCard_Click" Style="{StaticResource PrimaryButtonStyle}" Height="38"/>
                        </StackPanel>
                    </Grid>

                    <!-- Workspace Cards list -->
                    <ScrollViewer x:Name="BoardScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding DisplayCards}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding BackgroundImagePath, Converter={StaticResource BackgroundImageConverter}, TargetNullValue={x:Null}, FallbackValue=#1e1e28}" BorderThickness="1.5" CornerRadius="8" Margin="8"
                                            BorderBrush="{Binding BorderColor, Converter={StaticResource BorderColorConverter}}"
                                            PreviewMouseLeftButtonDown="Card_PreviewMouseLeftButtonDown" MouseMove="Card_MouseMove" 
                                            AllowDrop="True" Drop="Card_Drop" DragOver="Card_DragOver"
                                            DragEnter="Card_DragEnter" DragLeave="Card_DragLeave"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Width" Value="250"/>
                                                <Setter Property="Height" Value="300"/>
                                                <Setter Property="Opacity" Value="1.0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDimmed}" Value="True">
                                                        <Setter Property="Opacity" Value="0.35"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ShowImageSideBySide}" Value="True">
                                                        <Setter Property="Width" Value="480"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.LayoutTransform>
                                            <ScaleTransform ScaleX="{Binding ScaleFactor}" ScaleY="{Binding ScaleFactor}"/>
                                        </Border.LayoutTransform>
                                        <Border.Effect>
                                            <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="3" Opacity="0.4"/>
                                        </Border.Effect>
                                        <Grid Margin="12">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Title of the Card -->
                                            <TextBox Grid.Row="0" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" 
                                                     Background="Transparent" 
                                                     Foreground="{Binding ForegroundColor, Converter={StaticResource BorderColorConverter}, TargetNullValue={x:Null}, FallbackValue=#ffffff}" 
                                                     BorderThickness="0" 
                                                     Padding="4,6" FontSize="13" FontWeight="Bold" Margin="0,0,0,8" CaretBrush="#ffffff"
                                                     FontFamily="{Binding FontFamilyName}"/>

                                            <!-- Tag selection on the Card -->
                                             <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                                                 <TextBlock Text="Tag:" Foreground="#a0a0b5" VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                                 <ComboBox ItemsSource="{Binding DataContext.AvailableTagsWithNone, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           SelectedItem="{Binding CardTag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                           Style="{StaticResource DarkComboBoxStyle}"
                                                           Height="26" Width="95" FontSize="11" VerticalContentAlignment="Center"/>
                                                 <Button Content="📝" Click="EditCardDetails_Click" Style="{StaticResource AccentButtonStyle}" Width="26" Height="26" Margin="4,0,0,0" Padding="0" FontSize="11" ToolTip="Edit Details / Add Images"/>
                                                 <Button Content="↗" Click="PopOutCard_Click" Style="{StaticResource AccentButtonStyle}" Width="26" Height="26" Margin="4,0,0,0" Padding="0" FontSize="11" FontWeight="Bold" ToolTip="Pop Out Standalone Note Window"/>
                                                 
                                                 <!-- Popout Split Note Button (Only visible if there are images) -->
                                                 <Button Content="📑" Click="PopOutSplitCard_Click" Style="{StaticResource AccentButtonStyle}" Width="26" Height="26" Margin="4,0,0,0" Padding="0" FontSize="11.5" ToolTip="Pop Out Split Image/Note Window" Visibility="{Binding Images.Count, Converter={StaticResource CountToVisibilityConverter}}"/>

                                                 <!-- Side-by-side toggle button (Only visible if there are images) -->
                                                 <ToggleButton IsChecked="{Binding ShowImageSideBySide}" Style="{StaticResource PinToggleButtonStyle}" Width="26" Height="26" Margin="4,0,0,0" Padding="0" ToolTip="Toggle Side-by-Side Reference Image" Visibility="{Binding Images.Count, Converter={StaticResource CountToVisibilityConverter}}">
                                                     <ToggleButton.Content>
                                                         <TextBlock Text="📖" FontSize="11.5"/>
                                                     </ToggleButton.Content>
                                                 </ToggleButton>
                                             </StackPanel>

                                             <!-- Content area supporting Side-by-Side Reference Layout -->
                                             <Grid Grid.Row="2">
                                                 <Grid.ColumnDefinitions>
                                                     <ColumnDefinition Width="Auto"/>
                                                     <ColumnDefinition Width="*"/>
                                                 </Grid.ColumnDefinitions>

                                                 <!-- Pinned Image (Visible only when ShowImageSideBySide is true) -->
                                                 <Border Grid.Column="0" Width="180" CornerRadius="4" ClipToBounds="True" Margin="0,0,10,0" BorderBrush="#3a3a4c" BorderThickness="1"
                                                         Visibility="{Binding ShowImageSideBySide, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                     <Image Source="{Binding Images[0]}" Stretch="UniformToFill"/>
                                                 </Border>

                                                 <!-- Card Content Text Box -->
                                                 <TextBox Grid.Column="1" Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}" 
                                                          Background="Transparent" 
                                                          Foreground="{Binding ForegroundColor, Converter={StaticResource BorderColorConverter}, TargetNullValue={x:Null}, FallbackValue=#dcdce5}" 
                                                          BorderThickness="0" 
                                                          Padding="4" FontSize="12" AcceptsReturn="True" TextWrapping="Wrap" 
                                                          VerticalScrollBarVisibility="Auto" CaretBrush="#ffffff" AcceptsTab="True"
                                                          FontFamily="{Binding FontFamilyName}"/>
                                             </Grid>

                                            <!-- Bottom control panel inside Card -->
                                            <Grid Grid.Row="3" Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Content="◀" Click="MoveCardLeft_Click" 
                                                        Style="{StaticResource AccentButtonStyle}" Width="32" Height="28" 
                                                        FontSize="11" Padding="0" ToolTip="Move Left"/>
                                                <Button Grid.Column="1" Content="Delete Card" Click="DeleteCard_Click" 
                                                        Style="{StaticResource DeleteButtonStyle}" Height="28" Margin="6,0"/>
                                                <Button Grid.Column="2" Content="▶" Click="MoveCardRight_Click" 
                                                        Style="{StaticResource AccentButtonStyle}" Width="32" Height="28" 
                                                        FontSize="11" Padding="0" ToolTip="Move Right"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Graph Canvas View -->
                    <ScrollViewer x:Name="GraphScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <Canvas x:Name="GraphCanvas" Width="2000" Height="2000" Background="#0f0f14"
                                MouseLeftButtonDown="GraphCanvas_MouseLeftButtonDown"
                                MouseLeftButtonUp="GraphCanvas_MouseLeftButtonUp"
                                MouseMove="GraphCanvas_MouseMove"
                                MouseRightButtonDown="GraphCanvas_MouseRightButtonDown">
                            
                            <Canvas.ContextMenu>
                                <ContextMenu Style="{StaticResource DarkContextMenuStyle}">
                                    <MenuItem Header="Add New Note Here" Click="CanvasAddNote_Click"/>
                                </ContextMenu>
                            </Canvas.ContextMenu>
                            
                            <!-- Sub-canvas to draw lines programmatically in code-behind -->
                            <Canvas x:Name="ConnectionsCanvas" Width="2000" Height="2000" IsHitTestVisible="True"/>

                            <!-- Graph nodes items control -->
                            <ItemsControl x:Name="GraphNodesControl" ItemsSource="{Binding ActiveWorkspace.Cards}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas IsItemsHost="True"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding GraphX, Mode=TwoWay}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding GraphY, Mode=TwoWay}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{Binding BorderColor, Converter={StaticResource BorderColorConverter}}" BorderThickness="1.5" CornerRadius="6" Width="170" Height="110" Background="#1e1e28" Padding="10" PreviewMouseLeftButtonDown="Node_PreviewMouseLeftButtonDown" MouseMove="Node_MouseMove" PreviewMouseLeftButtonUp="Node_PreviewMouseLeftButtonUp" Cursor="SizeAll">
                                            <Border.ContextMenu>
                                                <ContextMenu Style="{StaticResource DarkContextMenuStyle}">
                                                    <MenuItem Header="Quick Link to another note..." Click="CardContextMenuLink_Click"/>
                                                    <MenuItem Header="Edit Note details..." Click="CardContextMenuEdit_Click"/>
                                                    <MenuItem Header="Delete Note" Click="CardContextMenuDelete_Click"/>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <!-- Card Title -->
                                                <TextBlock Grid.Row="0" Text="{Binding Title}" Foreground="#ffffff" FontSize="11" FontWeight="Bold" TextTrimming="CharacterEllipsis" Margin="0,0,0,4"/>
                                                <!-- Brief notes preview -->
                                                <TextBlock Grid.Row="1" Text="{Binding Content}" Foreground="#a0a0b5" FontSize="9.5" TextWrapping="Wrap" TextTrimming="WordEllipsis" LineHeight="12" Margin="0,0,10,0" Height="52"/>

                                                <!-- Dynamic tags list -->
                                                <TextBlock Grid.Row="2" Text="{Binding Tags, Converter={StaticResource TagsListConverter}}" Foreground="#8a8ab0" FontSize="8.5" TextTrimming="CharacterEllipsis"/>

                                                <!-- Circular Connection Anchor handle (Center-Right edge) -->
                                                <Ellipse x:Name="LinkAnchor" Width="12" Height="12" Fill="#5c2dd5" Stroke="#ffffff" StrokeThickness="1.5" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-16,0" Cursor="Hand" MouseLeftButtonDown="LinkAnchor_MouseLeftButtonDown"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Canvas>
                    </ScrollViewer>
                </Grid>

                <!-- Divider and Collapse Toggle Column -->
                <Grid x:Name="DividerPanel" Grid.Column="1" Background="#121218" Width="24" VerticalAlignment="Stretch">
                    <!-- Divider Line -->
                    <Border Background="#22222c" Width="2" HorizontalAlignment="Center"/>
                    <!-- Toggle Button -->
                    <Button x:Name="TogglePanelBtn" Content="›" Click="TogglePanel_Click" 
                            Style="{StaticResource AccentButtonStyle}" Padding="0" 
                            Width="16" Height="45" VerticalAlignment="Center" HorizontalAlignment="Center" 
                            FontSize="12" FontWeight="Bold"/>
                </Grid>

                <!-- ==================== RIGHT PANEL: GEMINI AI CHAT ==================== -->
                <Grid x:Name="ChatPanel" Grid.Column="2" Width="400" Background="#171720">
                    <Grid.RowDefinitions>
                        <!-- API Key Header -->
                        <RowDefinition Height="Auto"/>
                        <!-- Chat History Log -->
                        <RowDefinition Height="*"/>
                        <!-- Input Box and Send Button -->
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- API Key Header Area -->
                    <Grid x:Name="ApiKeyHeaderGrid" Grid.Row="0" Margin="16" SnapsToDevicePixels="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Gemini API Key:" Foreground="#a0a0b5" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12" FontWeight="SemiBold"/>
                        <PasswordBox x:Name="ApiKeyBox" Grid.Column="1" Background="#1e1e28" Foreground="#ffffff" BorderBrush="#2d2d3d" BorderThickness="1" Padding="8,6" VerticalAlignment="Center" PasswordChar="●"/>
                        <Button x:Name="SaveKeyBtn" Content="Save Key" Grid.Column="2" Click="SaveKey_Click" Style="{StaticResource AccentButtonStyle}" Margin="10,0,0,0" Height="30" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Chat History Area -->
                    <TextBox x:Name="ChatHistoryBox" Grid.Row="1" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" Background="#101017" Foreground="#f0f0f5" 
                             BorderBrush="#22222d" BorderThickness="1" Margin="16,0,16,8" Padding="12" 
                             FontSize="13.5" FontFamily="Segoe UI" CaretBrush="#ffffff"/>

                    <!-- Input and Send Box -->
                    <Grid Grid.Row="2" Margin="16,8,16,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <TextBox x:Name="ChatInputBox" Height="50" AcceptsReturn="True" TextWrapping="Wrap" 
                                     VerticalScrollBarVisibility="Auto" Background="#1e1e28" Foreground="#ffffff" 
                                     BorderBrush="#2d2d3d" BorderThickness="1" Padding="10,8" CaretBrush="#ffffff" 
                                     KeyDown="ChatInputBox_KeyDown" TextChanged="ChatInputBox_TextChanged"/>
                            <TextBlock x:Name="PlaceholderText" Text="Ask Gemini about your story beats..." 
                                       Foreground="#5a5a6a" Margin="14,10,0,0" IsHitTestVisible="False" 
                                       Visibility="Visible" FontSize="13" VerticalAlignment="Top"/>
                        </Grid>
                        <Button x:Name="SendBtn" Content="Send" Grid.Column="1" Click="SendBtn_Click" 
                                Style="{StaticResource PrimaryButtonStyle}" Margin="10,0,0,0" Width="80" Height="50"/>
                    </Grid>
                </Grid>
            </Grid>

            <!-- ==================== SETTINGS OVERLAY FLYOUT ==================== -->
            <Grid x:Name="SettingsOverlay" Grid.Row="0" Grid.RowSpan="2" Background="#cc080810" Visibility="Collapsed">
                <Border Background="#1a1a24" BorderBrush="#3a3a4c" BorderThickness="1.5" CornerRadius="10" 
                        Padding="24" Width="400" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="25" ShadowDepth="6" Opacity="0.7"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <TextBlock Grid.Row="0" Text="Application Settings" FontSize="18" FontWeight="Bold" Foreground="#ffffff" Margin="0,0,0,16"/>

                        <!-- Settings Body -->
                        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,0,0,20">
                            <!-- Enable AI checkbox -->
                            <CheckBox x:Name="EnableAiCheckbox" Content="Enable Streaming AI Assistant" Checked="EnableAiCheckbox_Changed" Unchecked="EnableAiCheckbox_Changed" Foreground="#ffffff" FontSize="13" Margin="0,0,0,16" VerticalContentAlignment="Center">
                                <CheckBox.Resources>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Style>
                                </CheckBox.Resources>
                            </CheckBox>

                            <!-- AI Provider Selector Panel -->
                            <StackPanel x:Name="AiProviderPanel" Orientation="Vertical" Margin="0,0,0,16" Visibility="Collapsed">
                                <TextBlock Text="AI Provider:" Foreground="#a0a0b5" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <ComboBox x:Name="AiProviderComboBox" Height="32" VerticalContentAlignment="Center"
                                          Style="{StaticResource DarkComboBoxStyle}" SelectionChanged="AiProviderComboBox_SelectionChanged">
                                    <ComboBoxItem Content="Gemini AI"/>
                                    <ComboBoxItem Content="Local Ollama"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Gemini API Config -->
                            <StackPanel x:Name="GeminiConfigPanel" Orientation="Vertical" Margin="0,0,0,16" Visibility="Collapsed">
                                <TextBlock Text="Gemini API Key:" Foreground="#a0a0b5" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <PasswordBox x:Name="SettingsApiKeyBox" Background="#1e1e28" Foreground="#ffffff" BorderBrush="#2d2d3d" BorderThickness="1" Padding="8,6" PasswordChar="●"/>
                            </StackPanel>

                            <!-- Ollama API Config -->
                            <StackPanel x:Name="OllamaConfigPanel" Orientation="Vertical" Margin="0,0,0,16" Visibility="Collapsed">
                                <TextBlock Text="Ollama API URL:" Foreground="#a0a0b5" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox x:Name="SettingsOllamaUrlBox" Background="#1e1e28" Foreground="#ffffff" BorderBrush="#2d2d3d" BorderThickness="1" Padding="8,6" CaretBrush="#ffffff" Margin="0,0,0,10"/>

                                <TextBlock Text="Ollama Model Name:" Foreground="#a0a0b5" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="OllamaModelComboBox" Grid.Column="0" Height="32" VerticalContentAlignment="Center"
                                              Style="{StaticResource DarkComboBoxStyle}" IsEditable="True"/>
                                    <Button Content="Refresh" Grid.Column="1" Click="RefreshOllamaModels_Click" Style="{StaticResource AccentButtonStyle}" Height="32" Margin="6,0,0,0" Padding="8,0"/>
                                </Grid>
                            </StackPanel>

                            <!-- Theme Selection -->
                            <TextBlock Text="Color Theme:" Foreground="#a0a0b5" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <ComboBox x:Name="ThemeComboBox" Height="32" VerticalContentAlignment="Center"
                                      Style="{StaticResource DarkComboBoxStyle}" Margin="0,0,0,12">

                                <ComboBoxItem Content="Midnight Purple"/>
                                <ComboBoxItem Content="Neon Teal"/>
                                <ComboBoxItem Content="Sunset Orange"/>
                                <ComboBoxItem Content="Forest Green"/>
                                <ComboBoxItem Content="Cyberpunk Pink"/>
                            </ComboBox>

                            <!-- Drag and Drop toggle -->
                            <CheckBox x:Name="EnableDragDropCheckbox" Content="Enable drag-and-drop card reordering" IsEnabled="False" ToolTip="Drag-and-drop is temporarily disabled" Foreground="#5a5a6a" FontSize="13" Margin="0,4,0,0" VerticalContentAlignment="Center">
                                <CheckBox.Resources>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="Cursor" Value="No"/>
                                    </Style>
                                </CheckBox.Resources>
                            </CheckBox>

                            <!-- Disable GPU Hardware Acceleration -->
                            <CheckBox x:Name="DisableHardwareAccelerationCheckbox" Content="Disable GPU Hardware Acceleration (Software Only)" Foreground="#ffffff" FontSize="13" Margin="0,10,0,0" VerticalContentAlignment="Center" ToolTip="Check this if you experience graphics driver resets or crashes while overlaying games.">
                                <CheckBox.Resources>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Style>
                                </CheckBox.Resources>
                            </CheckBox>

                            <!-- Reset Flyout Scale / Size button -->
                            <Button Content="Reset Flyout Scale &amp; Window Sizes" Click="ResetFlyoutScale_Click" Style="{StaticResource AccentButtonStyle}" Height="28" Margin="0,16,0,12"/>

                            <!-- Global Hotkeys Config Expander -->
                            <Expander Header="Global System Hotkeys" Foreground="#ffffff" FontSize="12.5" FontWeight="SemiBold" BorderBrush="#2d2d3d" BorderThickness="0,1,0,1" Margin="0,4,0,16" Padding="0,8">
                                <StackPanel Orientation="Vertical" Margin="0,8,0,0">
                                    <!-- Enable global hotkeys checkbox -->
                                    <CheckBox x:Name="EnableGlobalHotkeysCheckbox" Content="Enable Global Keybinds" Checked="EnableHotkeys_CheckedChanged" Unchecked="EnableHotkeys_CheckedChanged" Foreground="#ffffff" FontSize="12" Margin="0,0,0,12" VerticalContentAlignment="Center">
                                    </CheckBox>

                                    <!-- Hotkey keybind fields (Key Recorder buttons) -->
                                    <TextBlock Text="New Note Hotkey:" Foreground="#a0a0b5" FontSize="11.5" Margin="0,0,0,4"/>
                                    <Button x:Name="HotkeyNewNoteBtn" Content="Ctrl+Shift+N" Click="HotkeyRecordBtn_Click" Style="{StaticResource AccentButtonStyle}" HorizontalContentAlignment="Left" Padding="10,6" Height="32" Margin="0,0,0,10" ToolTip="Click to record hotkey"/>

                                    <TextBlock Text="Focus Popout Hotkey:" Foreground="#a0a0b5" FontSize="11.5" Margin="0,0,0,4"/>
                                    <Button x:Name="HotkeyFocusNoteBtn" Content="Ctrl+Shift+F" Click="HotkeyRecordBtn_Click" Style="{StaticResource AccentButtonStyle}" HorizontalContentAlignment="Left" Padding="10,6" Height="32" Margin="0,0,0,10" ToolTip="Click to record hotkey"/>

                                    <TextBlock Text="Toggle Click-Through Hotkey:" Foreground="#a0a0b5" FontSize="11.5" Margin="0,0,0,4"/>
                                    <Button x:Name="HotkeyToggleLockBtn" Content="Ctrl+Shift+K" Click="HotkeyRecordBtn_Click" Style="{StaticResource AccentButtonStyle}" HorizontalContentAlignment="Left" Padding="10,6" Height="32" Margin="0,0,0,14" ToolTip="Click to record hotkey"/>

                                    <!-- Blocklist of apps -->
                                    <TextBlock Text="Block Global Hotkeys in these apps:" Foreground="#a0a0b5" FontSize="11.5" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBox x:Name="BlockedProcessesBox" ToolTip="Enter process names (e.g. discord, chrome, notepad, msdev) separated by commas. Hotkeys will be ignored when these apps have window focus." Background="#1e1e28" Foreground="#ffffff" BorderBrush="#2d2d3d" BorderThickness="1" Padding="6,4" FontSize="12" Margin="0,0,0,6" CaretBrush="#ffffff"/>
                                </StackPanel>
                            </Expander>
                        </StackPanel>

                        <!-- Buttons -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="Cancel" Grid.Column="0" Height="34" Click="CloseSettings_Click" Style="{StaticResource AccentButtonStyle}"/>
                            <Button Content="Save &amp; Apply" Grid.Column="2" Height="34" Click="SaveSettings_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ==================== TAGS OVERLAY FLYOUT ==================== -->
            <Grid x:Name="TagsOverlay" Grid.Row="0" Grid.RowSpan="2" Background="#cc080810" Visibility="Collapsed">
                <Border Background="#1a1a24" BorderBrush="#3a3a4c" BorderThickness="1.5" CornerRadius="10" 
                        Padding="24" Width="400" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="25" ShadowDepth="6" Opacity="0.7"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <TextBlock Grid.Row="0" Text="Manage Tags" FontSize="18" FontWeight="Bold" Foreground="#ffffff" Margin="0,0,0,16"/>

                        <!-- Tags List & Add Form -->
                        <Grid Grid.Row="1" Margin="0,0,0,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="180"/>
                            </Grid.RowDefinitions>

                            <!-- Add Tag Form -->
                            <Grid Grid.Row="0" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="NewTagTextBox" Background="#1e1e28" Foreground="#ffffff" 
                                         BorderBrush="#2d2d3d" BorderThickness="1" Padding="8,6" FontSize="13" 
                                         VerticalContentAlignment="Center" CaretBrush="#ffffff"/>
                                <Button Content="Add Tag" Grid.Column="1" Click="AddTag_Click" 
                                        Style="{StaticResource PrimaryButtonStyle}" Margin="10,0,0,0" Height="32"/>
                            </Grid>

                            <!-- Existing Tags Scroll List -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="TagsListControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding}" Foreground="#ffffff" FontSize="13.5" VerticalAlignment="Center"/>
                                                <Button Content="Delete" Grid.Column="1" Click="DeleteTag_Click" Tag="{Binding}"
                                                        Style="{StaticResource DeleteButtonStyle}" Height="26" Padding="8,2"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>

                        <!-- Close Button -->
                        <Grid Grid.Row="2">
                            <Button Content="Close" Height="34" Click="CloseTags_Click" Style="{StaticResource AccentButtonStyle}"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ==================== CARD DETAIL OVERLAY FLYOUT ==================== -->
            <Grid x:Name="CardDetailOverlay" Grid.Row="0" Grid.RowSpan="2" Background="#cc080810" Visibility="Collapsed">
                <Border Background="#1a1a24" BorderBrush="#3a3a4c" BorderThickness="1.5" CornerRadius="10" 
                        Padding="24" Width="780" Height="580" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding ScaleFactor}" ScaleY="{Binding ScaleFactor}"/>
                    </Border.LayoutTransform>
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="25" ShadowDepth="6" Opacity="0.7"/>
                    </Border.Effect>
                    <Grid>
                        <Grid x:Name="CardDetailGrid">
                        <Grid.RowDefinitions>
                            <!-- Title & Close -->
                            <RowDefinition Height="Auto"/>
                            <!-- Content Details (split columns) -->
                            <RowDefinition Height="*"/>
                            <!-- Images Section (thumbnails) -->
                            <RowDefinition Height="Auto"/>
                            <!-- Footer Action buttons -->
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header Area -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="DetailTitleBox" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#14141c" Foreground="{Binding ForegroundColor, Converter={StaticResource BorderColorConverter}, TargetNullValue={x:Null}, FallbackValue=#ffffff}" BorderBrush="#2e2e3d" BorderThickness="1" 
                                     Padding="10,8" FontSize="16" FontWeight="Bold" CaretBrush="#ffffff" VerticalContentAlignment="Center"/>
                            <Button Content="✕" Click="CloseCardDetail_Click" Grid.Column="1" Style="{StaticResource TitleBarButtonStyle}" Width="36" Height="36" Margin="10,0,0,0" FontSize="14"/>
                        </Grid>

                        <!-- Main Split Content Area -->
                        <Grid Grid.Row="1" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left: Large Notes Content -->
                            <Grid Grid.Column="0" Margin="0,0,16,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Detailed Story Notes &amp; beats:" Foreground="#a0a0b5" FontSize="12.5" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Border Grid.Row="1" BorderBrush="#2e2e3d" BorderThickness="1" CornerRadius="4" ClipToBounds="True">
                                    <Grid Background="{Binding BackgroundImagePath, Converter={StaticResource BackgroundImageConverter}, TargetNullValue={x:Null}, FallbackValue=#14141c}">
                                        <TextBox x:Name="DetailContentBox" Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="Transparent" 
                                                 Foreground="{Binding ForegroundColor, Converter={StaticResource BorderColorConverter}, TargetNullValue={x:Null}, FallbackValue=#dcdce5}" 
                                                 BorderThickness="0" 
                                                 Padding="10" FontSize="13.5" AcceptsReturn="True" TextWrapping="Wrap" 
                                                 VerticalScrollBarVisibility="Auto" CaretBrush="#ffffff" AcceptsTab="True"
                                                 FontFamily="{Binding FontFamilyName}">
                                            <TextBox.LayoutTransform>
                                                <ScaleTransform ScaleX="{Binding ScaleFactor}" ScaleY="{Binding ScaleFactor}"/>
                                            </TextBox.LayoutTransform>
                                        </TextBox>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- Right: Controls (Tag, Color picker, Styles, Export) -->
                            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Orientation="Vertical" Margin="0,0,4,0">
                                    <!-- Tag selection -->
                                    <TextBlock Text="Card Tag:" Foreground="#a0a0b5" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding AvailableTagsWithNone}"
                                              SelectedItem="{Binding CardTag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{StaticResource DarkComboBoxStyle}"
                                              Height="30" Margin="0,0,0,12" VerticalContentAlignment="Center"/>

                                    <!-- Font selection -->
                                    <TextBlock Text="Font Family:" Foreground="#a0a0b5" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding DataContext.SystemFontsList, RelativeSource={RelativeSource AncestorType=Window}}"
                                              SelectedItem="{Binding FontFamilyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{StaticResource DarkComboBoxStyle}"
                                              Height="30" Margin="0,0,0,12" VerticalContentAlignment="Center">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontFamily="{Binding}" FontSize="12.5"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <!-- Background Customization -->
                                    <TextBlock Text="Background Texture:" Foreground="#a0a0b5" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Button Grid.Column="0" Grid.Row="0" Content="Default" Click="BackgroundDefault_Click" Style="{StaticResource AccentButtonStyle}" Height="26" Margin="0,0,3,4" Padding="0" FontSize="11"/>
                                        <Button Grid.Column="1" Grid.Row="0" Content="Parchment" Click="BackgroundParchment_Click" Style="{StaticResource AccentButtonStyle}" Height="26" Margin="3,0,0,4" Padding="0" FontSize="11"/>
                                        <Button Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Content="Upload Custom Image..." Click="BackgroundUpload_Click" Style="{StaticResource AccentButtonStyle}" Height="26" Margin="0,2,0,0" Padding="0" FontSize="11"/>
                                    </Grid>

                                    <!-- Scale slider -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Zoom / Scale:" Foreground="#a0a0b5" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding ScaleFactor, StringFormat={}{0:F2}x}" Foreground="#ffffff" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider Minimum="0.5" Maximum="2.0" Value="{Binding ScaleFactor}" Margin="0,0,0,12" Focusable="False" SmallChange="0.05" LargeChange="0.2"/>

                                    <!-- Opacity slider -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Opacity / Fade:" Foreground="#a0a0b5" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding ContentOpacity, StringFormat={}{0:P0}}" Foreground="#ffffff" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider Minimum="0.15" Maximum="1.0" Value="{Binding ContentOpacity}" Margin="0,0,0,12" Focusable="False" SmallChange="0.05" LargeChange="0.1"/>

                                    <!-- Border Color Selection -->
                                    <TextBlock Text="Border Highlight Color:" Foreground="#a0a0b5" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <UniformGrid Columns="3" Rows="3" Margin="0,0,0,12" HorizontalAlignment="Left">
                                        <Button Style="{StaticResource CircularColorButtonStyle}" Click="ColorCircle_Click" Tag="" ToolTip="Default" BorderThickness="1" BorderBrush="#3a3a4c" Background="#22222c"/>
                                        <Button Style="{StaticResource CircularColorButtonStyle}" Click="ColorCircle_Click" Tag="#00bfa5" ToolTip="Teal" Background="#00bfa5"/>
                                        <Button Style="{StaticResource CircularColorButtonStyle}" Click="ColorCircle_Click" Tag="#ff6d00" ToolTip="Orange" Background="#ff6d00"/>
                                        <Button Style="{StaticResource CircularColorButtonStyle}" Click="ColorCircle_Click" Tag="#00c853" ToolTip="Green" Background="#00c853"/>
                                        <Button Style="{StaticResource CircularColorButtonStyle}" Click="ColorCircle_Click" Tag="#ff007f" ToolTip="Pink" Background="#ff007f"/>
                                        <Button Style="{StaticResource CircularColorButtonStyle}" Click="ColorCircle_Click" Tag="#5c2dd5" ToolTip="Purple" Background="#5c2dd5"/>
                                        <Button Style="{StaticResource CircularColorButtonStyle}" Click="ColorCircle_Click" Tag="#d32f2f" ToolTip="Red" Background="#d32f2f"/>
                                        <Button Style="{StaticResource CircularColorButtonStyle}" Click="ColorCircle_Click" Tag="#fbc02d" ToolTip="Yellow" Background="#fbc02d"/>
                                        <Button Style="{StaticResource CircularColorButtonStyle}" Click="ColorCircle_Click" Tag="#1976d2" ToolTip="Blue" Background="#1976d2"/>
                                    </UniformGrid>

                                    <!-- Text/Foreground Color Selection -->
                                    <TextBlock Text="Text/Notes Color:" Foreground="#a0a0b5" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,6"/>
                                    <UniformGrid Columns="3" Rows="2" Margin="0,0,0,12" HorizontalAlignment="Left">
                                        <Button Style="{StaticResource CircularColorButtonStyle}" Click="TextColorCircle_Click" Tag="" ToolTip="Default Theme" BorderThickness="1" BorderBrush="#3a3a4c" Background="#22222c"/>
                                        <Button Style="{StaticResource CircularColorButtonStyle}" Click="TextColorCircle_Click" Tag="#ffffff" ToolTip="White" Background="#ffffff"/>
                                        <Button Style="{StaticResource CircularColorButtonStyle}" Click="TextColorCircle_Click" Tag="#000000" ToolTip="Black" Background="#000000"/>
                                        <Button Style="{StaticResource CircularColorButtonStyle}" Click="TextColorCircle_Click" Tag="#222222" ToolTip="Charcoal" Background="#222222"/>
                                        <Button Style="{StaticResource CircularColorButtonStyle}" Click="TextColorCircle_Click" Tag="#3e2723" ToolTip="Dark Brown" Background="#3e2723"/>
                                        <Button Style="{StaticResource CircularColorButtonStyle}" Click="TextColorCircle_Click" Tag="#0a192f" ToolTip="Dark Navy" Background="#0a192f"/>
                                    </UniformGrid>

                                    <!-- Export specific card -->
                                    <Button Content="📤 Share Card (.noticecard)" Click="ExportCard_Click" Style="{StaticResource AccentButtonStyle}" Height="30" Margin="0,6,0,0" FontSize="11.5"/>

                                    <!-- Separator Line -->
                                    <Border BorderBrush="#2e2e3d" BorderThickness="0,1,0,0" Margin="0,12,0,12"/>

                                    <!-- Related notes list -->
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Related Notes:" Foreground="#a0a0b5" FontSize="12.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <Button Content="Link" Grid.Column="1" Click="AddCardRelationship_Click" Style="{StaticResource AccentButtonStyle}" Padding="6,2" FontSize="11" Height="24"/>
                                    </Grid>
                                    
                                    <ListBox x:Name="RelatedNotesListBox" Background="#14141c" BorderBrush="#2e2e3d" BorderThickness="1" MaxHeight="100" Margin="0,0,0,12">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Foreground="#b39ddb" FontSize="11.5" Cursor="Hand" TextTrimming="CharacterEllipsis" PreviewMouseLeftButtonUp="RelatedNoteLink_Click">
                                                    <Run Text="{Binding Relationship, StringFormat=[{0}]}" Foreground="#8e8e9f"/>
                                                    <Run Text="{Binding Card.Title}" FontWeight="SemiBold"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <!-- Bottom: Attached Images area -->
                        <Grid Grid.Row="2" Margin="0,0,0,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Attached Visual References:" Foreground="#a0a0b5" FontSize="12.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Button Content="+ Add Image" Grid.Column="1" Click="AddCardImage_Click" Style="{StaticResource AccentButtonStyle}" Padding="8,3" FontSize="11.5" Height="26"/>
                            </Grid>

                            <!-- Horizontal thumbnails list -->
                            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Height="90" Background="#14141c" BorderBrush="#2e2e3d" BorderThickness="1" Margin="0">
                                <ItemsControl x:Name="DetailImagesList" ItemsSource="{Binding Images}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="6"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="6,0" Width="100" Height="70">
                                                <Border BorderBrush="#3a3a4c" BorderThickness="1" CornerRadius="4" ClipToBounds="True">
                                                    <!-- Clicking image pops out window -->
                                                    <Button Click="Thumbnail_Click" Padding="0" BorderThickness="0" Background="Transparent" Cursor="Hand" ToolTip="Click to pop out window">
                                                        <Image Source="{Binding}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="LowQuality"/>
                                                    </Button>
                                                </Border>
                                                
                                                <!-- Delete button overlay -->
                                                <Button Content="✕" Click="DeleteCardImage_Click" Tag="{Binding}"
                                                        HorizontalAlignment="Right" VerticalAlignment="Top" 
                                                        Width="18" Height="18" Margin="0,2,2,0" Padding="0" FontSize="9"
                                                        Background="#d32f2f" Foreground="#ffffff" BorderThickness="0" Cursor="Hand"
                                                        ToolTip="Delete Image"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>

                        <!-- Footer Actions -->
                        <Grid Grid.Row="3">
                            <Button Content="Done" Height="34" Click="CloseCardDetail_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                        </Grid>
                        </Grid>
                        
                        <!-- Resizing Grip Thumb -->
                        <Thumb Width="16" Height="16" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="-16,-16,-16,-16" Cursor="SizeNWSE" DragDelta="FlyoutResize_DragDelta">
                            <Thumb.Template>
                                <ControlTemplate TargetType="Thumb">
                                    <Grid Background="Transparent">
                                        <Path Data="M 6 12 L 12 6 M 9 12 L 12 9 M 12 12 L 12 12" Stroke="#a0a0b5" StrokeThickness="1.5"/>
                                    </Grid>
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                    </Grid>
                </Border>
            </Grid>

            <!-- ==================== CREATE RELATIONSHIP OVERLAY ==================== -->
            <Grid x:Name="RelationshipOverlay" Grid.Row="0" Grid.RowSpan="2" Background="#cc080810" Visibility="Collapsed">
                <Border Background="#1a1a24" BorderBrush="#3a3a4c" BorderThickness="1.5" CornerRadius="10" 
                        Padding="24" Width="380" Height="420" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="25" ShadowDepth="6" Opacity="0.7"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <TextBlock Grid.Row="0" Text="Link to Another Note" FontSize="16" FontWeight="Bold" Foreground="#ffffff" Margin="0,0,0,16"/>

                        <!-- Body -->
                        <Grid Grid.Row="1" Margin="0,0,0,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="Search Target Note:" Foreground="#a0a0b5" FontSize="11.5" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox Grid.Row="1" x:Name="LinkSearchTextBox" Height="30" Background="#1e1e28" Foreground="#ffffff" BorderBrush="#2d2d3d" BorderThickness="1" Padding="8,4" CaretBrush="#ffffff" TextChanged="LinkSearchTextBox_TextChanged" Margin="0,0,0,8"/>
                            
                            <ListBox Grid.Row="2" x:Name="LinkSearchListBox" Background="#14141c" BorderBrush="#2e2e3d" BorderThickness="1" Height="140" DisplayMemberPath="Title">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Foreground" Value="#ffffff"/>
                                        <Setter Property="Padding" Value="8,4"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#5c2dd5"/>
                                                <Setter Property="Foreground" Value="#ffffff"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#2d2d3d"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>

                            <TextBlock Grid.Row="3" Text="Relationship Label (e.g. leads to, knows):" Foreground="#a0a0b5" FontSize="11.5" FontWeight="SemiBold" Margin="0,8,0,4"/>
                            <TextBox Grid.Row="4" x:Name="LinkLabelTextBox" Height="30" Background="#1e1e28" Foreground="#ffffff" BorderBrush="#2d2d3d" BorderThickness="1" Padding="8,4" CaretBrush="#ffffff" Text="relates to"/>
                        </Grid>

                        <!-- Buttons -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="Cancel" Grid.Column="0" Height="34" Click="CloseRelationship_Click" Style="{StaticResource AccentButtonStyle}"/>
                            <Button Content="Create Link" Grid.Column="2" Height="34" Click="CreateRelationship_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
