<Window x:Class="StoryBoardAI.SplitNoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:StoryBoardAI"
        Title="NoticeBoard Map Note" Height="500" Width="850"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="Manual" ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True" Topmost="{Binding IsPinned}">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="10"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Converter for custom border colors -->
        <local:BorderColorConverter x:Key="BorderColorConverter"/>

        <!-- Background Image Converter -->
        <local:BackgroundImageConverter x:Key="BackgroundImageConverter"/>

        <!-- Header Button Style -->
        <Style x:Key="OverlayTitleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#a0a0b5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3a3a4c"/>
                    <Setter Property="Foreground" Value="#ffffff"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Toggle Button Style for Pin -->
        <Style x:Key="PinToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3a3a4c"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5c2dd5"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Color Circle Button Style -->
        <Style x:Key="ColorCircleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Ellipse Fill="{TemplateBinding Tag}" Stroke="#444" StrokeThickness="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main Container supporting ScaleTransform and Opacity -->
    <Grid x:Name="WindowRoot" Opacity="{Binding ContentOpacity}">
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="{Binding ScaleFactor}" ScaleY="{Binding ScaleFactor}"/>
        </Grid.LayoutTransform>

        <!-- Main Outer Border -->
        <Border x:Name="OuterBorder" BorderThickness="2" CornerRadius="10" ClipToBounds="True"
                BorderBrush="{Binding BorderColor, Converter={StaticResource BorderColorConverter}}"
                Background="{Binding BackgroundImagePath, Converter={StaticResource BackgroundImageConverter}}">
            
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Header control panel (30px) -->
                    <RowDefinition Height="30"/>
                    <!-- Main Split-Screen Row -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 1. Header Control Panel (Drag bar) -->
                <Grid x:Name="HeaderPanel" Grid.Row="0" Background="#0f0f14" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Title Drag / Edit Area -->
                    <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" 
                             Background="Transparent" 
                             Foreground="{Binding ForegroundColor, Converter={StaticResource BorderColorConverter}, TargetNullValue={x:Null}, FallbackValue=#ffffff}" 
                             BorderThickness="0"
                             FontWeight="Bold" FontSize="12.5" VerticalAlignment="Center" Margin="10,0,0,0"
                             CaretBrush="White"/>

                    <!-- Control Buttons Panel -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0" WindowChrome.IsHitTestVisibleInChrome="True">
                        <!-- Transparency Control -->
                        <TextBlock Text="💡" VerticalAlignment="Center" FontSize="11" Margin="6,0,2,0" ToolTip="Opacity"/>
                        <Slider Width="45" Minimum="0.15" Maximum="1.0" Value="{Binding ContentOpacity}" 
                                VerticalAlignment="Center" Margin="0,0,6,0" Focusable="False" ToolTip="Adjust Opacity"/>

                        <!-- Scale Control -->
                        <TextBlock Text="🔍" VerticalAlignment="Center" FontSize="11" Margin="4,0,2,0" ToolTip="Scale"/>
                        <Slider Width="45" Minimum="0.5" Maximum="2.0" Value="{Binding ScaleFactor}" 
                                VerticalAlignment="Center" Margin="0,0,6,0" Focusable="False" ToolTip="Adjust Scale"/>

                        <!-- Reset Scale/Opacity button -->
                        <Button Style="{StaticResource OverlayTitleButtonStyle}" Content="↺" Click="ResetScaleOpacity_Click" ToolTip="Reset Scale &amp; Opacity" Width="20" Height="20" FontSize="11" Margin="0,0,4,0"/>

                        <!-- Pin Button -->
                        <ToggleButton Style="{StaticResource PinToggleButtonStyle}" IsChecked="{Binding IsPinned}" ToolTip="Toggle Click-Through Overlay">
                            <ToggleButton.Content>
                                <TextBlock Text="📌" FontSize="11"/>
                            </ToggleButton.Content>
                        </ToggleButton>

                        <!-- Minimize Button -->
                        <Button Style="{StaticResource OverlayTitleButtonStyle}" Content="─" Click="Minimize_Click" ToolTip="Minimize"/>

                        <!-- Close Button -->
                        <Button Style="{StaticResource OverlayTitleButtonStyle}" Content="✕" Click="Close_Click" ToolTip="Save &amp; Close"/>
                    </StackPanel>
                </Grid>

                <!-- 2. Main Content Split View -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <!-- Left Column: Image Canvas Drawing -->
                        <ColumnDefinition Width="*" MinWidth="200"/>
                        <!-- Grid Splitter -->
                        <ColumnDefinition Width="5"/>
                        <!-- Right Column: Note text editor -->
                        <ColumnDefinition Width="*" MinWidth="150"/>
                    </Grid.ColumnDefinitions>

                    <!-- COLUMN 0: Image & Drawing Canvas Panel -->
                    <Grid Grid.Column="0" Background="#14141d">
                        <Grid.RowDefinitions>
                            <!-- Drawing Toolbar -->
                            <RowDefinition Height="38"/>
                            <!-- Drawing Canvas Container -->
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Drawing toolbar -->
                        <Border Grid.Row="0" Background="#181824" BorderBrush="#262635" BorderThickness="0,0,0,1" Padding="8,4" WindowChrome.IsHitTestVisibleInChrome="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Pencil / Eraser toggle -->
                                <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                                    <RadioButton x:Name="PenRadio" IsChecked="True" Content="✏️ Draw" Checked="PenRadio_Checked" Foreground="#ffffff" FontSize="11.5" Margin="0,0,12,0"/>
                                    <RadioButton x:Name="EraserRadio" Content="🧽 Erase" Checked="EraserRadio_Checked" Foreground="#ffffff" FontSize="11.5"/>
                                </StackPanel>

                                <!-- Colors selection (Pencils) -->
                                <StackPanel x:Name="ColorPanel" Orientation="Horizontal" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Button Style="{StaticResource ColorCircleButtonStyle}" Tag="#FF3333" Click="Color_Click" ToolTip="Red Pencil"/>
                                    <Button Style="{StaticResource ColorCircleButtonStyle}" Tag="#FFFF33" Click="Color_Click" ToolTip="Yellow Pencil"/>
                                    <Button Style="{StaticResource ColorCircleButtonStyle}" Tag="#33FF33" Click="Color_Click" ToolTip="Green Pencil"/>
                                    <Button Style="{StaticResource ColorCircleButtonStyle}" Tag="#3399FF" Click="Color_Click" ToolTip="Blue Pencil"/>
                                    <Button Style="{StaticResource ColorCircleButtonStyle}" Tag="#FFFFFF" Click="Color_Click" ToolTip="White Pencil"/>
                                    
                                    <!-- Stroke Thickness -->
                                    <TextBlock Text="Size:" Foreground="#a0a0b5" FontSize="11" Margin="14,0,4,0" VerticalAlignment="Center"/>
                                    <Slider x:Name="ThicknessSlider" Width="55" Minimum="1" Maximum="15" Value="3" 
                                            ValueChanged="ThicknessSlider_ValueChanged" VerticalAlignment="Center" Focusable="False"/>
                                </StackPanel>

                                <!-- Clear Canvas -->
                                <Button Grid.Column="2" Content="🗑️ Clear Drawings" Click="ClearInk_Click" 
                                        Background="#3b1d28" Foreground="#ff6680" BorderBrush="#5d2638" BorderThickness="1" 
                                        Padding="8,2" FontSize="11" VerticalAlignment="Center" Cursor="Hand">
                                    <Button.Resources>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Drawing Canvas Container -->
                        <Grid Grid.Row="1" x:Name="DrawingAreaGrid" SizeChanged="DrawingAreaGrid_SizeChanged" ClipToBounds="True">
                            <!-- Image underlay -->
                            <Image x:Name="UnderlayImage" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            
                            <!-- Ink Canvas overlay wrapper -->
                            <InkCanvas x:Name="DrawingCanvas" Background="Transparent" 
                                       EditingMode="Ink"
                                       HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                       WindowChrome.IsHitTestVisibleInChrome="True"/>
                        </Grid>
                    </Grid>

                    <!-- COLUMN 1: Resizable Splitter -->
                    <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#1e1e28" ResizeBehavior="PreviousAndNext" WindowChrome.IsHitTestVisibleInChrome="True"/>

                    <!-- COLUMN 2: Scrollable Note TextBox -->
                    <TextBox x:Name="NotesContentBox" Grid.Column="2" Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" AcceptsTab="True" VerticalScrollBarVisibility="Auto"
                             Background="Transparent" 
                             Foreground="{Binding ForegroundColor, Converter={StaticResource BorderColorConverter}, TargetNullValue={x:Null}, FallbackValue=#dcdce5}" 
                             BorderThickness="0" Padding="12"
                             CaretBrush="#ffffff" FontSize="13.5"
                             FontFamily="{Binding FontFamilyName}"
                             WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
