<Window x:Class="StoryBoardAI.FloatingImageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Image Reference" Height="450" Width="600"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="8"/>
    </WindowChrome.WindowChrome>

    <Border Background="#1a1a24" BorderBrush="#3a3a4c" BorderThickness="1.5" CornerRadius="8" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <!-- Title Drag Bar (30px) -->
                <RowDefinition Height="30"/>
                <!-- Image Display Area -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Drag Bar -->
            <Grid Grid.Row="0" Background="#0f0f14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="📌 Image Reference" Foreground="#ffffff" FontSize="11.5" FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0,0,0"/>

                <Button Content="✕" Click="CloseBtn_Click" Grid.Column="1" VerticalAlignment="Center" Width="30" Height="30" Cursor="Hand" BorderThickness="0" Background="Transparent" Foreground="#a0a0b5" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#c42b2b"/>
                                    <Setter Property="Foreground" Value="#ffffff"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Image display -->
            <Grid Grid.Row="1" Margin="8">
                <Image x:Name="DisplayImg" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
            </Grid>
        </Grid>
    </Border>
</Window>
